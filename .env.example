# SmartFlow Systems - SmartFlow Hub Environment Configuration Example
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env or .env.local to version control!
# .env* files are already in .gitignore

# ===========================================
# Anthropic Claude API Configuration
# ===========================================
# Get your API key from https://console.anthropic.com/
# This is the primary API key for Claude integration
SmartFlow_Hub=your-anthropic-api-key-here

# Alternative: Standard Anthropic API key environment variable
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ===========================================
# Next.js Configuration
# ===========================================
# Next.js will automatically use these if present
# Typically set automatically in development
# NODE_ENV=development

# ===========================================
# Server Configuration (Optional)
# ===========================================
# PORT=3000
# HOST=0.0.0.0

# ===========================================
# Analytics & Monitoring (Optional)
# ===========================================
# Google Analytics tracking ID
# NEXT_PUBLIC_GA_TRACKING_ID=UA-XXXXXXXXX-X

# ===========================================
# Public Environment Variables
# ===========================================
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# Be careful not to expose sensitive information

# Example: API base URL for client-side requests
# NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ===========================================
# Logging & Debugging
# ===========================================
# NEXT_PUBLIC_DEBUG=false
